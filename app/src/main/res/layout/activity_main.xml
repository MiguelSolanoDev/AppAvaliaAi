<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/CriarEventos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="25dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Logo -->
            <ImageView
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:paddingEnd="5dp"
                app:srcCompat="@drawable/ic_logo" />


            <!-- Nome e subtítulo -->

            <!-- Foto usuário -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="AvaliaAí"
                    android:textColor="@color/VerdeDosBotões"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Crie e Avalie"
                    android:textColor="@color/TextoIcones"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgUser"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/empty_icon"
                app:shapeAppearanceOverlay="@style/CircleImageView" />

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnProcurarEventos"
            android:layout_width="0dp"
            android:layout_height="119dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnMeusEventos"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/degrade_verde_btn"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <!-- Ícone calendário lupa -->
                <ImageView
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Procurar Eventos"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_calendariolupa" />

                <!-- Espaço entre ícone e texto -->
                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content" />

                <!-- Texto -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Procurar Eventos"
                    android:textColor="#2E2E2E"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <!-- Ícone seta -->
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:contentDescription="Ir para procurar eventos"
                    android:src="@drawable/ic_setaf" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnCriarEventos"
            android:layout_width="0dp"
            android:layout_height="119dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="150dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toTopOf="@+id/btnMeusEventos"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.54"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/headerLayout"
            app:strokeWidth="0dp">

            <!-- Layout interno com gradient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/degrade_verde_btn"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <!-- Ícone calendário -->

                <!-- Espaço entre ícone e texto -->

                <ImageView
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Criar Evento"
                    android:cropToPadding="false"
                    android:rotationX="0"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_calendariomais"
                    android:visibility="visible" />

                <Space
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <!-- Texto -->

                <!-- Ícone seta -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Criar Eventos"
                    android:textColor="#2E2E2E"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:contentDescription="Ir para criar eventos"
                    android:src="@drawable/ic_setaf" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnMeusEventos"
            android:layout_width="0dp"
            android:layout_height="119dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toTopOf="@+id/btnProcurarEventos"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnCriarEventos"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/degrade_verde_btn"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="0dp">

                <!-- Ícone calendário certo -->
                <ImageView
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Meus Eventos"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_calendariocerto" />

                <!-- Espaço entre ícone e texto -->
                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content" />

                <!-- Texto -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Meus Eventos"
                    android:textColor="#2E2E2E"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <!-- Ícone seta -->
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:contentDescription="Ir para meus eventos"
                    android:src="@drawable/ic_setaf" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>



    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>