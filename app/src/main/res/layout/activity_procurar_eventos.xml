<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ProcurarEventos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.ProcurarEventosActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.10462287" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideEnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.9" />

                <!-- BOTÃO VOLTAR -->
                <ImageButton
                    android:id="@+id/btnVoltar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="22dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Voltar"
                    android:src="@drawable/ic_voltar"
                    app:layout_constraintStart_toEndOf="@id/guideStart"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvTitulo"/>

                <!-- TÍTULO -->
                <TextView
                    android:id="@+id/tvTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="17dp"
                    android:text="Procura de Eventos"
                    android:textColor="@color/TextoDosBotoes"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btnVoltar"
                    app:layout_constraintEnd_toStartOf="@id/imgUser"
                    app:layout_constraintHorizontal_bias="0.5"/>

                <!-- FOTO PERFIL -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgUser"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/empty_icon"
                    app:layout_constraintEnd_toStartOf="@id/guideEnd"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvTitulo"
                    app:shapeAppearanceOverlay="@style/CircleImageView" />

                <!-- LINHA DIVISÓRIA -->
                <View
                    android:id="@+id/divisorHeader"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:background="@color/CinzaQuaseBranco"
                    app:layout_constraintTop_toBottomOf="@id/imgUser"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- BUSCA -->
            <LinearLayout
                android:id="@+id/layoutBusca"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="20dp">

                <EditText
                    android:id="@+id/editBusca"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search"
                    android:hint="Buscar eventos por nome, tema ou palavra"
                    android:paddingStart="12dp"/>

                <ImageButton
                    android:id="@+id/btnFiltro"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_filtro"
                    android:src="@drawable/ic_camera"/>
            </LinearLayout>

            <!-- FILTROS -->
            <HorizontalScrollView
                android:id="@+id/scrollFiltros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingStart="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnHoje"
                        style="@style/TagStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="Hoje"
                        android:textColor="@color/TextoIcones"
                        android:backgroundTint="@color/white"
                        app:cornerRadius="5dp"/>

                    <Button
                        android:id="@+id/btnOnline"
                        style="@style/TagStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:text="Online"
                        android:textColor="@color/TextoIcones"
                        android:backgroundTint="@color/white"
                        app:cornerRadius="5dp"/>

                    <Button
                        android:id="@+id/btnPresencial"
                        style="@style/TagStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:text="Presencial"
                        android:textColor="@color/TextoIcones"
                        android:backgroundTint="@color/white"
                        app:cornerRadius="5dp"/>

                    <Button
                        android:id="@+id/btnSemana"
                        style="@style/TagStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:text="Essa Semana"
                        android:textColor="@color/TextoIcones"
                        android:backgroundTint="@color/white"
                        app:cornerRadius="5dp"/>

                    <Button
                        android:id="@+id/btnHibrido"
                        style="@style/TagStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:text="Híbrido"
                        android:textColor="@color/TextoIcones"
                        android:backgroundTint="@color/white"
                        app:cornerRadius="5dp"/>

                    <Button
                        android:id="@+id/btnAtivo"
                        style="@style/TagStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginStart="8dp"
                        android:text="Ativo"
                        android:textColor="@color/TextoIcones"
                        android:backgroundTint="@color/white"
                        app:cornerRadius="5dp"/>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- TELA VAZIA -->
            <LinearLayout
                android:id="@+id/layoutEstadoVazio"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_calendariomais" />

                <TextView
                    android:id="@+id/txtMensagem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Não há eventos criados"
                    android:textColor="@color/TextoDosBotoes"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnAcao"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Criar Evento"
                    app:cornerRadius="5dp" />

            </LinearLayout>

            <!-- LISTA DE EVENTOS -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerEventos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_evento"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>