<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ProcurarEventos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.ProcurarEventosActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.10462287" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.9" />

    <!-- BOTÃO VOLTAR -->
    <ImageButton
        android:id="@+id/btnVoltar"
        android:layout_width="17dp"
        android:layout_height="17dp"
        android:layout_marginTop="22dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Voltar"
        android:src="@drawable/ic_voltar"
        app:layout_constraintStart_toStartOf="@id/guideStart"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvTitulo"/>

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="73dp"
        android:layout_marginTop="17dp"
        android:layout_marginEnd="73dp"
        android:text="Procura de Eventos"
        android:textColor="@color/TextoDosBotoes"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/imgUser"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@id/btnVoltar"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- FOTO PERFIL -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgUser"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/empty_icon"
        app:layout_constraintEnd_toStartOf="@id/guideEnd"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@id/tvTitulo"
        app:shapeAppearanceOverlay="@style/CircleImageView" />

    <!-- LINHA DIVISÓRIA -->
    <View
        android:id="@+id/divisorHeader"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/CinzaQuaseBranco"
        app:layout_constraintTop_toBottomOf="@id/imgUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BUSCA -->
    <LinearLayout
        android:id="@+id/layoutBusca"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@id/guideEnd"
        app:layout_constraintTop_toTopOf="@id/divisorHeader"
        app:layout_constraintStart_toEndOf="@id/guideStart"
        android:paddingTop="25dp">

        <EditText
            android:id="@+id/editBusca"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search"
            android:hint="Buscar eventos por nome, tema ou palavra"
            android:paddingStart="12dp"/>

        <ImageButton
            android:id="@+id/btnFiltro"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_filtro"
            android:src="@drawable/ic_camera"/>
    </LinearLayout>

    <!-- FILTROS -->
    <HorizontalScrollView
        android:id="@+id/scrollFiltros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toStartOf="@id/guideEnd"
        app:layout_constraintTop_toBottomOf="@id/layoutBusca"
        app:layout_constraintStart_toEndOf="@id/guideStart">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:id="@+id/btnHoje"
                app:cornerRadius="5dp"
                style="@style/TagStyle"
                android:textColor = "@color/TextoIcones"
                android:backgroundTint="@color/white"
                android:text="Hoje"/>
            <Button
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:id="@+id/btnOnline"
                app:cornerRadius="5dp"
                style="@style/TagStyle"
                android:textColor = "@color/TextoIcones"
                android:backgroundTint="@color/white"
                android:text="Online"
                android:layout_marginStart="8dp"/>
            <Button
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:textColor = "@color/TextoIcones"
                android:id="@+id/btnPresencial"
                app:cornerRadius="5dp"
                style="@style/TagStyle"
                android:backgroundTint="@color/white"
                android:text="Presencial"
                android:layout_marginStart="8dp"/>
            <Button
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:textColor = "@color/TextoIcones"
                android:id="@+id/btnSemana"
                app:cornerRadius="5dp"
                style="@style/TagStyle"
                android:backgroundTint="@color/white"
                android:text="Essa Semana"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/layoutListaEventos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/scrollFiltros"
        app:layout_constraintStart_toStartOf="@id/guideStart"
        app:layout_constraintEnd_toEndOf="@id/guideEnd">
        <!-- LISTA DE EVENTOS -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerEventos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>

        <!-- TELA VAZIA -->
        <LinearLayout
            android:id="@+id/layoutEstadoVazio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

        </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>