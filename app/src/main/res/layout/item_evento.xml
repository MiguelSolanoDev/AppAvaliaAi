<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- IMAGEM -->

        <!-- CONTEÚDO -->
        <ImageView
            android:id="@+id/imgEvento"
            android:layout_width="100dp"
            android:layout_height="110dp"
            android:background="@drawable/bg_image_rounded"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:layout_gravity="center_vertical"
            android:src="@drawable/futb" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <!-- TÍTULO -->
            <TextView
                android:id="@+id/txtTitulo"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- DATA + HORA -->
            <TextView
                android:id="@+id/txtData"
                android:textSize="14sp"
                android:textColor="#777"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- TAGS -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tagStatus"
                    style="@style/TagStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/tag_status_bg"/>

                <TextView
                    android:id="@+id/tagModalidade"
                    style="@style/TagStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tag_modalidade_bg"/>
            </LinearLayout>

            <!-- TIPO -->
            <TextView
                android:id="@+id/tagTipo"
                style="@style/TagStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/tag_tipo_bg"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- LADO DIREITO -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- SETA -->
            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/ic_setaf"
                android:layout_gravity="center"
                android:layout_weight="1"/>

            <!-- AVALIAÇÃO -->
            <TextView
                android:id="@+id/txtAvaliacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="10dp"
                android:text="⭐ 4.8"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>